{
  "appId": "com.zota.cpos",
  "productName": "Zota CPOS",
  "directories": {
    "output": "release",
    "buildResources": "assets"
  },
  "files": [
    "dist/**/*",
    "!**/node_modules/**/.local-chromium/**",
    "!**/node_modules/**/puppeteer/.local-chromium/**",
    "!**/node_modules/**/.cache/**",
    "!**/node_modules/**/phantomjs-prebuilt/lib/phantom/bin/**",
    "!**/node_modules/**/phantomjs-prebuilt/lib/phantom/examples/**",
    "!**/node_modules/**/*.md",
    "!**/node_modules/**/*.ts",
    "!**/node_modules/**/*.map",
    "!**/node_modules/**/test/**",
    "!**/node_modules/**/tests/**",
    "!**/node_modules/**/__tests__/**",
    "!**/node_modules/**/docs/**",
    "!**/node_modules/**/example/**",
    "!**/node_modules/**/examples/**",
    "!**/node_modules/**/CHANGELOG*",
    "!**/node_modules/**/LICENSE*",
    "!**/node_modules/**/README*"
  ],
  "asar": false,
  "extraResources": [
    {
      "from": "../zota-react-frontend/build",
      "to": "frontend"
    },
    {
      "from": "assets/schema.sql",
      "to": "schema.sql"
    }
  ],
  "win": {
    "target": [
      {
        "target": "msi",
        "arch": [
          "x64"
        ]
      }
    ],
    "icon": "assets/icon.ico",
    "requestedExecutionLevel": "asInvoker"
  },
  "compression": "normal",
  "msi": {
    "perMachine": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "runAfterFinish": true
  },
  "publish": {
    "provider": "github",
    "owner": "saipranay-nextech",
    "repo": "zota-updates-acme",
    "private": true
  }
}
